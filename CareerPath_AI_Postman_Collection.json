{
  "info": {
    "name": "CareerPath AI API",
    "description": "Complete API collection for testing CareerPath AI backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🏥 Health & Test",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "health"]
            },
            "description": "Check if server is running"
          },
          "response": []
        },
        {
          "name": "Test Route",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/test",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "test"]
            },
            "description": "Test if API is working"
          },
          "response": []
        }
      ]
    },
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@email.com\",\n  \"password\": \"password123\",\n  \"passwordConfirm\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/signup",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "signup"]
            },
            "description": "Register a new user - SAVE THE TOKEN!"
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@email.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "login"]
            },
            "description": "Login user and get JWT token"
          },
          "response": []
        },
        {
          "name": "Protected Route - Get Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/auth/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "me"]
            },
            "description": "Protected route - requires JWT token. Replace YOUR_TOKEN_HERE with actual token from login"
          },
          "response": []
        }
      ]
    },
    {
      "name": "🤖 Roadmap (AI Generated)",
      "item": [
        {
          "name": "Generate Roadmap",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"goal\": \"Become a Full Stack Developer\",\n  \"skills\": \"HTML, CSS, JavaScript basics\",\n  \"duration\": \"6 months\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/roadmap/generate",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "roadmap", "generate"]
            },
            "description": "Generate AI roadmap using Gemini API. IMPORTANT: Add your Gemini API key to .env first!"
          },
          "response": []
        },
        {
          "name": "Get All User Roadmaps",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/roadmap",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "roadmap"]
            },
            "description": "Get all roadmaps created by logged-in user"
          },
          "response": []
        },
        {
          "name": "Get Single Roadmap",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/roadmap/ROADMAP_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "roadmap", "ROADMAP_ID_HERE"]
            },
            "description": "Get details of a specific roadmap. Replace ROADMAP_ID_HERE with actual ID from 'Get All User Roadmaps'"
          },
          "response": []
        },
        {
          "name": "Delete Roadmap",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/roadmap/ROADMAP_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "roadmap", "ROADMAP_ID_HERE"]
            },
            "description": "Delete a roadmap. Replace ROADMAP_ID_HERE with actual ID"
          },
          "response": []
        }
      ]
    }
  ]
}
