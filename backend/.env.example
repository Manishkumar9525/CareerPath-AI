# Server Configuration
PORT=5000
NODE_ENV=development

CLIENT_URL=http://localhost:3000

# MongoDB Connection
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/careerpath_ai

# JWT Secret (min 32 characters, use strong random string)
JWT_SECRET=your_jwt_secret_key_min_32_chars_long_random_string

# Gemini AI API
GEMINI_API_KEY=your_gemini_api_key_here

# GROQ API
GROQ_API_KEY=your_groq_api_key_here

# YouTube API
YOUTUBE_API_KEY=your_youtube_api_key_here

# Email Configuration (for OTP)
GMAIL_USER=your_gmail_address_here
GMAIL_PASSWORD=your_gmail_app_password_here

# Cloudinary Configuration (standardized)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

